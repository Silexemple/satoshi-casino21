{
  "functions": {
    "api/deposit.js": {
      "maxDuration": 15
    },
    "api/withdraw.js": {
      "maxDuration": 15
    },
    "api/check-payment/[hash].js": {
      "maxDuration": 15
    },
    "api/game.js": {
      "maxDuration": 10
    },
    "api/table/[id]/action.js": {
      "maxDuration": 10
    },
    "api/table/[id]/bet.js": {
      "maxDuration": 10
    },
    "api/tournament/play.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
