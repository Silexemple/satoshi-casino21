# ── Satoshi Casino 21 — variables d'environnement ──
# Copier vers Vercel (Project Settings → Environment Variables).

# Connexion NWC (NIP-47) du wallet Lightning du casino.
# Généré dans Alby Hub / Alby (Connections → app, avec budget plafonné).
# Permissions requises: make_invoice, lookup_invoice, pay_invoice.
# ⚠️ Le wallet (ex. Alby Hub sur Umbrel) doit rester EN LIGNE, sinon les dépôts
#    échouent avec "NWC timeout". Utiliser une connexion DÉDIÉE au casino.
NWC_URL=nostr+walletconnect://<pubkey>?relay=wss://relay.example&secret=<hex64>

# Token admin (dashboard /admin.html, endpoints /api/admin & /api/nwc-health).
# Chaîne aléatoire longue (ex: openssl rand -hex 32).
ADMIN_TOKEN=change_me_long_random_hex

# Vercel KV (Upstash) — injectés automatiquement par l'intégration Vercel KV.
# En local: vercel env pull .env.local
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
